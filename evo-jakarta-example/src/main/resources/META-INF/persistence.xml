<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.2">

    <persistence-unit name="evo-jakarta" transaction-type="RESOURCE_LOCAL">
        <class>dev.cominotti.java.evo.jakarta.example.greeting.Greeting</class>
        <class>dev.cominotti.java.evo.persistence.EmailConverter</class>
        <class>dev.cominotti.java.evo.persistence.CpfConverter</class>
        <class>dev.cominotti.java.evo.persistence.CnpjConverter</class>
        <class>dev.cominotti.java.evo.persistence.CpfOrCnpjConverter</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:evojakarta"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
